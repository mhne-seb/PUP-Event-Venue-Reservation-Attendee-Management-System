@model List<PUPEventVenue.Models.Venue>
@{
    ViewData["Title"] = "Browse Venues";
    Layout = "_Layout";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-building me-2"></i>@(User.IsInRole("Admin") ? "Manage Venues" : "Browse Venues")</h1>
                <p class="mb-0 opacity-75">@(User.IsInRole("Admin") ? "Manage and organize venues" : "Find the perfect venue for your event")</p>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-gold fw-bold rounded-pill px-4">
                    <i class="fas fa-plus me-2"></i>Add Venue
                </a>
            }
        </div>
    </div>
</div>

<div class="container pb-5">
    <!-- Search/Filter -->
    <form method="get" class="card border-0 shadow-sm rounded-xl p-3 mb-4">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label small fw-semibold">Search</label>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control rounded-pill" placeholder="Search by name or location..." />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Availability</label>
                <select name="available" class="form-select rounded-pill">
                    <option value="">All Venues</option>
                    <option value="true" selected="@(ViewBag.Available?.ToString() == "True")">Available Only</option>
                    <option value="false" selected="@(ViewBag.Available?.ToString() == "False")">Unavailable</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-pup rounded-pill flex-grow-1"><i class="fas fa-search me-1"></i>Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-3"><i class="fas fa-times"></i></a>
            </div>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
            <h5>No venues found</h5>
            <p>Try adjusting your search filters.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var venue in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="venue-card h-100">
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(venue.ImageUrl))
                            {
                                <img src="@venue.ImageUrl" alt="@venue.Name" class="card-img-top" onerror="this.onerror=null;this.src='/images/venues/default-venue.jpg';" />
                            }
                            else
                            {
                                <div class="venue-img-placeholder">
                                    <i class="fas fa-building fa-3x text-white opacity-50"></i>
                                </div>
                            }
                            <span class="position-absolute top-0 end-0 m-2 badge @(venue.IsAvailable ? "bg-success" : "bg-secondary") rounded-pill">
                                @(venue.IsAvailable ? "Available" : "Unavailable")
                            </span>
                        </div>
                        <div class="card-body p-3">
                            <h5 class="fw-bold mb-1">@venue.Name</h5>
                            <p class="text-muted small mb-1"><i class="fas fa-map-marker-alt me-1 text-maroon"></i>@venue.Location</p>
                            <p class="text-muted small mb-2"><i class="fas fa-users me-1 text-maroon"></i>Capacity: <strong>@venue.Capacity.ToString("N0")</strong> persons</p>
                            <p class="text-muted small mb-3 lh-sm" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@venue.Description</p>
                            <div class="mb-3">
                                @foreach (var a in venue.AmenitiesList.Take(4))
                                {
                                    <span class="amenity-pill"><i class="fas fa-check me-1"></i>@a</span>
                                }
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@venue.VenueId" class="btn btn-pup-outline btn-sm flex-grow-1 rounded-pill">
                                    <i class="fas fa-info-circle me-1"></i>Details
                                </a>
                                @if (!User.IsInRole("Admin") && User.Identity?.IsAuthenticated == true && venue.IsAvailable)
                                {
                                    <a asp-controller="Reservations" asp-action="Create" asp-route-venueId="@venue.VenueId" class="btn btn-pup btn-sm flex-grow-1 rounded-pill">
                                        <i class="fas fa-calendar-plus me-1"></i>Reserve
                                    </a>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@venue.VenueId" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
