@model List<PUPEventVenue.Models.Reservation>
@{
    ViewData["Title"] = "Reports & Analytics";
    Layout = "_Layout";
    var venues = ViewBag.Venues as List<PUPEventVenue.Models.Venue> ?? new();
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-chart-bar me-2"></i>Reports & Analytics</h1>
    </div>
</div>

<div class="container pb-5">
    <!-- Filter Form -->
    <form method="get" class="card border-0 shadow-sm rounded-xl p-4 mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">From Date</label>
                <input type="date" name="from" value="@ViewBag.From" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">To Date</label>
                <input type="date" name="to" value="@ViewBag.To" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Filter by Venue</label>
                <select name="venueId" class="form-select">
                    <option value="">All Venues</option>
                    @foreach (var v in venues)
                    {
                        <option value="@v.VenueId" selected="@(ViewBag.VenueId == v.VenueId.ToString())">@v.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-pup rounded-pill w-100"><i class="fas fa-filter me-1"></i>Generate Report</button>
            </div>
        </div>
    </form>

    <!-- Summary Stats -->
    <div class="row g-3 mb-4">
        @foreach (var (label, val, color) in new[]{
            ("Total", Model.Count, "#8B0000"),
            ("Pending", Model.Count(r => r.Status == "Pending"), "#D97706"),
            ("Approved", Model.Count(r => r.Status == "Approved"), "#059669"),
            ("Rejected", Model.Count(r => r.Status == "Rejected"), "#DC2626"),
            ("Total Attendees", Model.SelectMany(r => r.Attendees).Count(), "#2563EB")
        })
        {
            <div class="col-6 col-md">
                <div class="card border-0 shadow-sm rounded-xl p-3 text-center">
                    <div class="fs-2 fw-bold" style="color:@color;">@val</div>
                    <div class="small text-muted">@label</div>
                </div>
            </div>
        }
    </div>

    <!-- Reservations Table -->
    <div class="card border-0 shadow-sm rounded-xl overflow-hidden">
        <div class="card-header bg-white px-4 pt-3 pb-2 d-flex justify-content-between align-items-center border-0">
            <h5 class="section-title mb-0">Reservation Records</h5>
            <span class="text-muted small">@Model.Count records found</span>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
                <p>No records found for the selected period.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-pup mb-0">
                    <thead>
                        <tr><th>#</th><th>Event</th><th>Venue</th><th>Organizer</th><th>Date</th><th>Attendees</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td class="small text-muted">#@r.ReservationId</td>
                                <td>
                                    <div class="fw-semibold small">@r.EventName</div>
                                    <div class="small text-muted">@r.EventType</div>
                                </td>
                                <td class="small">@r.Venue?.Name</td>
                                <td>
                                    <div class="small fw-semibold">@r.Organizer?.FullName</div>
                                    <div class="small text-muted">@r.Organizer?.OrganizationName</div>
                                </td>
                                <td class="small">@r.StartDateTime.ToString("MMM dd, yyyy")</td>
                                <td class="small"><i class="fas fa-users me-1 text-muted"></i>@r.Attendees.Count</td>
                                <td><span class="badge badge-@r.Status.ToLower() rounded-pill px-2">@r.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
