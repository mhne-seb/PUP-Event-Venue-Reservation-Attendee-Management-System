@model IEnumerable<Payment>

@{
    ViewData["Title"] = "My Payments";
}

<div class="container mt-5">
    <div class="mb-4">
        <h2>💳 My Payment History</h2>
        <p class="text-muted">Track all your reservation payments and their status</p>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Payment ID</th>
                        <th>Event Name</th>
                        <th>Amount</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int count = 1;
                    }
                    @foreach (var payment in Model)
                    {
                        <tr>
                            <td>@(count++)</td>
                            <td><span class="badge bg-primary">#@payment.PaymentId</span></td>
                            <td>@payment.Reservation?.EventName</td>
                            <td><strong style="color: #28a745; font-size: 1.1em;">₱@payment.Amount.ToString("F2")</strong></td>
                            <td>@payment.DurationHours hour(s) &#64; ₱@payment.HourlyRate.ToString("F2")/hr</td>
                            <td>
                                <span class="badge" style="background-color: @GetStatusColor(payment.Status); font-size: 0.9em;">
                                    @GetStatusIcon(payment.Status) @payment.Status
                                </span>
                            </td>
                            <td>@payment.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a href="@Url.Action("Details", new { id = payment.PaymentId })"
                                   class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                @if (payment.Status == "Pending")
                                {
                                    <a href="@Url.Action("SubmitReceipt", new { reservationId = payment.ReservationId })"
                                       class="btn btn-sm btn-primary">
                                        <i class="fas fa-upload"></i> Upload
                                    </a>
                                }
                                @if (payment.Status == "Rejected")
                                {
                                    <a href="@Url.Action("SubmitReceipt", new { reservationId = payment.ReservationId })"
                                       class="btn btn-sm btn-warning">
                                        <i class="fas fa-redo"></i> Resubmit
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4">
            <a href="@Url.Action("Index", "Reservations")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Reservations
            </a>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <h5>📭 No payments yet</h5>
            <p class="mb-3">You haven't made any reservations with payments.</p>
            <a href="@Url.Action("Index", "Venues")" class="btn btn-primary">
                <i class="fas fa-plus"></i> Make a Reservation
            </a>
        </div>
    }
</div>

@functions {
    private string GetStatusColor(string status)
    {
        return status switch
        {
            "Pending" => "#6c757d",
            "Submitted" => "#ffc107",
            "Verified" => "#17a2b8",
            "Approved" => "#28a745",
            "Rejected" => "#dc3545",
            _ => "#007bff"
        };
    }

    private string GetStatusIcon(string status)
    {
        return status switch
        {
            "Pending" => "⏳",
            "Submitted" => "📤",
            "Verified" => "✅",
            "Approved" => "✅",
            "Rejected" => "❌",
            _ => "❓"
        };
    }
}
