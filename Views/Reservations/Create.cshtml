@model PUPEventVenue.ViewModels.ReservationCreateViewModel
@{
    ViewData["Title"] = "New Reservation Request";
    Layout = "_Layout";
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-calendar-plus me-2"></i>New Reservation Request</h1>
        @if (Model.Venue != null)
        {
            <p class="mb-0 opacity-75">Reserving: <strong>@Model.Venue.Name</strong></p>
        }
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @if (Model.Venue != null)
            {
                <div class="card border-0 shadow-sm rounded-xl p-3 mb-4 d-flex flex-row gap-3 align-items-center">
                    <div class="venue-img-placeholder rounded-xl" style="width:80px;height:60px;min-width:80px;">
                        <i class="fas fa-building text-white opacity-50"></i>
                    </div>
                    <div>
                        <div class="fw-bold">@Model.Venue.Name</div>
                        <div class="small text-muted"><i class="fas fa-map-marker-alt me-1"></i>@Model.Venue.Location</div>
                        <div class="small text-muted"><i class="fas fa-users me-1"></i>Capacity: @Model.Venue.Capacity.ToString("N0")</div>
                        @if (Model.Venue.PricePerHour > 0)
                        {
                            <div class="small text-muted"><i class="fas fa-tag me-1"></i>₱@Model.Venue.PricePerHour.ToString("F2") / hr</div>
                        }
                    </div>
                </div>
            }

            <div class="card border-0 shadow-sm rounded-xl">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" id="reservationForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="VenueId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small rounded-xl"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="EventName" class="form-label">Event Name *</label>
                                <input asp-for="EventName" class="form-control" placeholder="e.g. General Assembly 2025" />
                                <span asp-validation-for="EventName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EventType" class="form-label">Event Type</label>
                                <select asp-for="EventType" class="form-select">
                                    <option value="">Select type...</option>
                                    <option>Seminar / Webinar</option>
                                    <option>General Assembly</option>
                                    <option>Sports Event</option>
                                    <option>Cultural Show</option>
                                    <option>Academic Conference</option>
                                    <option>Organizational Meeting</option>
                                    <option>Exhibit / Fair</option>
                                    <option>Other</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ExpectedAttendees" class="form-label">Expected Attendees *</label>
                                <input asp-for="ExpectedAttendees" type="number" class="form-control" min="1" max="@(Model.Venue?.Capacity ?? 100000)" />
                                @if (Model.Venue != null)
                                {
                                    <div class="form-text">Max capacity: @Model.Venue.Capacity.ToString("N0")</div>
                                }
                                <span asp-validation-for="ExpectedAttendees" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="StartDateTime" class="form-label">Start Date & Time *</label>
                                <input asp-for="StartDateTime" type="datetime-local" class="form-control" id="startDt" />
                                <span asp-validation-for="StartDateTime" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDateTime" class="form-label">End Date & Time *</label>
                                <input asp-for="EndDateTime" type="datetime-local" class="form-control" id="endDt" />
                                <span asp-validation-for="EndDateTime" class="text-danger small"></span>
                            </div>

                            <!-- Availability Checker -->
                            <div class="col-12" id="availabilityResult" style="display:none;"></div>

                            <div class="col-12">
                                <label asp-for="EventDescription" class="form-label">Event Description</label>
                                <textarea asp-for="EventDescription" class="form-control" rows="4" placeholder="Describe your event, purpose, activities planned..."></textarea>
                            </div>
                        </div>

                        <div class="mt-4">
                            @if (Model.Venue?.PricePerHour > 0)
                            {
                                <div class="alert alert-warning border rounded-3 mb-3">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <i class="fas fa-credit-card text-warning fs-5"></i>
                                        <strong>Payment Required</strong>
                                    </div>
                                    <div class="row g-2 small">
                                        <div class="col-6">Hourly Rate:</div>
                                        <div class="col-6 text-end fw-semibold">₱@Model.Venue.PricePerHour.ToString("F2") / hr</div>
                                        <div class="col-6">Duration:</div>
                                        <div class="col-6 text-end fw-semibold" id="calcDuration">— hrs</div>
                                        <div class="col-12"><hr class="my-1" /></div>
                                        <div class="col-6 fs-6 fw-bold">Total Amount Due:</div>
                                        <div class="col-6 text-end fs-5 fw-bold text-success" id="calcTotal">₱0.00</div>
                                    </div>
                                    <div class="mt-2 small text-muted">
                                        <i class="fas fa-info-circle me-1"></i>
                                        You will be asked to upload your payment receipt after submitting.
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info rounded-xl py-2 small">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Your reservation will be reviewed by the admin. You'll receive a notification once it's approved or rejected.
                                </div>
                            }
                        </div>

                        <div class="d-flex gap-2 mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-pup px-4 rounded-pill fw-bold">
                                <i class="fas fa-paper-plane me-2"></i>Submit Request
                            </button>
                            <a asp-controller="Venues" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const venueId = @Model.VenueId;
const pricePerHour = @(Model.Venue?.PricePerHour ?? 0);
let checkTimeout;

function checkAvailability() {
    const start = document.getElementById('startDt').value;
    const end   = document.getElementById('endDt').value;
    const resultDiv = document.getElementById('availabilityResult');

    if (!start || !end) { resultDiv.style.display = 'none'; return; }

    clearTimeout(checkTimeout);
    checkTimeout = setTimeout(async () => {
        try {
            const res = await fetch(`/Venues/CheckAvailability?venueId=${venueId}&start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`);
            const data = await res.json();
            resultDiv.style.display = 'block';
            if (data.available) {
                resultDiv.innerHTML = '<div class="alert alert-success rounded-xl py-2 small"><i class="fas fa-check-circle me-1"></i>This time slot is available!</div>';
            } else {
                resultDiv.innerHTML = '<div class="alert alert-warning rounded-xl py-2 small"><i class="fas fa-exclamation-triangle me-1"></i>There\'s a conflict with existing bookings during this time.</div>';
            }
        } catch (e) { resultDiv.style.display = 'none'; }
    }, 600);
}

function recalculate() {
    if (pricePerHour <= 0) return;
    const startVal = document.getElementById('startDt').value;
    const endVal   = document.getElementById('endDt').value;
    if (!startVal || !endVal) return;

    const start  = new Date(startVal);
    const end    = new Date(endVal);
    const diffMs = end - start;

    if (diffMs <= 0) {
        document.getElementById('calcDuration').textContent = '— hrs';
        document.getElementById('calcTotal').textContent    = '₱0.00';
        return;
    }

    const hours = Math.ceil(diffMs / (1000 * 60 * 60));
    const total = hours * pricePerHour;

    document.getElementById('calcDuration').textContent =
        hours + ' hr' + (hours !== 1 ? 's' : '');
    document.getElementById('calcTotal').textContent =
        '₱' + total.toLocaleString('en-PH', { minimumFractionDigits: 2 });
}

document.getElementById('startDt').addEventListener('change', () => { checkAvailability(); recalculate(); });
document.getElementById('endDt').addEventListener('change',   () => { checkAvailability(); recalculate(); });
recalculate();
</script>
}